<?xml version="1.0" ?>
<robot name="kuka_kr6">
  <link name="base_link">
    <inertial>
      <mass value="20.0"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry><cylinder length="0.2" radius="0.1"/></geometry>
      <material name="orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    </visual>
  </link>

  <joint name="joint_a1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <parent link="base_link"/>
    <child link="link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-2.96" upper="2.96" velocity="6.28"/>
  </joint>

  <link name="link_1">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.1"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.1"/>
      <geometry><cylinder length="0.2" radius="0.08"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="joint_a2" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.2"/>
    <parent link="link_1"/>
    <child link="link_2"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-3.31" upper="0.78" velocity="5.23"/>
  </joint>

  <link name="link_2">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.2"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.2"/>
      <geometry><box size="0.1 0.1 0.4"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="joint_a3" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.4"/>
    <parent link="link_2"/>
    <child link="link_3"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-2.09" upper="2.72" velocity="6.28"/>
  </joint>

  <link name="link_3">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry><box size="0.08 0.08 0.1"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="joint_a4" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.1"/>
    <parent link="link_3"/>
    <child link="link_4"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-3.22" upper="3.22" velocity="6.65"/>
  </joint>

  <link name="link_4">
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0.2 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.2 0 0"/>
      <geometry><box size="0.4 0.06 0.06"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="joint_a5" type="revolute">
    <origin rpy="0 0 0" xyz="0.4 0 0"/>
    <parent link="link_4"/>
    <child link="link_5"/>
    <axis xyz="0 1 0"/>
    <limit effort="100" lower="-2.09" upper="2.09" velocity="6.77"/>
  </joint>

  <link name="link_5">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0.05 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0.05 0 0"/>
      <geometry><box size="0.1 0.05 0.05"/></geometry>
      <material name="orange"/>
    </visual>
  </link>

  <joint name="joint_a6" type="revolute">
    <origin rpy="0 0 0" xyz="0.1 0 0"/>
    <parent link="link_5"/>
    <child link="ee_link"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" lower="-6.10" upper="6.10" velocity="10.73"/>
  </joint>

  <link name="ee_link">
    <inertial>
      <mass value="0.5"/>
      <origin xyz="0.02 0 0"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <origin rpy="0 1.57 0" xyz="0.02 0 0"/>
      <geometry><cylinder length="0.04" radius="0.04"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
    </visual>
  </link>

  <!-- High-Accuracy Parallel Gripper -->
  <link name="gripper_base">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0.02 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0.02 0 0"/>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0.02 0 0"/>
      <geometry><box size="0.04 0.08 0.04"/></geometry>
    </collision>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="ee_link"/>
    <child link="gripper_base"/>
    <origin xyz="0.04 0 0"/>
  </joint>

  <link name="gripper_left">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.025 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.01 0.03"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.01 0.03"/></geometry>
    </collision>
  </link>

  <joint name="gripper_left_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_left"/>
    <origin xyz="0.04 -0.03 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="50" lower="0" upper="0.025" velocity="0.1"/>
  </joint>

  <link name="gripper_right">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0.025 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.01 0.03"/></geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.01 0.03"/></geometry>
    </collision>
  </link>

  <joint name="gripper_right_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="gripper_right"/>
    <origin xyz="0.04 0.03 0"/>
    <axis xyz="0 -1 0"/>
    <limit effort="50" lower="0" upper="0.025" velocity="0.1"/>
  </joint>
</robot>
